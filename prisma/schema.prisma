// Loom & Pearl — Custom Jewelry E-commerce
// Prisma schema: auth, inventory, catalog, orders, friend profiles

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum Role {
  CUSTOMER
  ADMIN
}

enum BeadSize {
  MM6
  MM8
  MM10
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ---------- Auth (NextAuth compatible) ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  friendProfiles FriendProfile[]
  orders         Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Inventory Matrix ----------

model FinishType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model PackagingType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Bead {
  id         String   @id @default(cuid())
  name       String
  hexCode    String? // solid color swatch
  textureUrl String? // optional texture/photo override
  finish     String   @default("MATTE") // references FinishType.name
  size       BeadSize @default(MM8)
  price      Float    @default(0)
  stock      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([size])
  @@index([isActive])
}

model Charm {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  price     Float    @default(0)
  stock     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([isActive])
}

model PackagingOption {
  id        String   @id @default(cuid())
  type      String // references PackagingType.name
  name      String
  imageUrl  String?
  price     Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive])
}

// ---------- Ready-made Catalog ----------

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String
  heroImageUrl String
  basePrice    Float    @default(0)
  wristSize    String   @default("MEDIUM") // SMALL(16) / MEDIUM(20) / LARGE(22)
  beadConfig   Json // ordered array of { beadId, hexCode, finish } snapshots
  charmId      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  charm      Charm?      @relation(fields: [charmId], references: [id])
  orderItems OrderItem[]

  @@index([isActive])
}

// ---------- Orders ----------

model Order {
  id              String      @id @default(cuid())
  userId          String?
  status          OrderStatus @default(PENDING)
  subtotal        Float
  packagingTotal  Float       @default(0)
  deliveryCharge  Float       @default(250)
  total           Float
  shippingName    String
  shippingAddress String
  shippingCity    String
  shippingPostal  String
  shippingCountry String
  giftNote        String?
  paymentMethod       String  @default("COD") // COD | JAZZCASH_EASYPAISA
  paymentReference    String?
  paymentScreenshotUrl String?
  trackingNumber  String?
  carrier         String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  productId     String? // set if based on a ready-made product
  designSnapshot Json // full custom design: beads[], charmId, wristSize, packaging
  quantity      Int     @default(1)
  unitPrice     Float
  lineTotal     Float

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

// ---------- Multi-profile "Design for a Friend" ----------

model FriendProfile {
  id          String   @id @default(cuid())
  ownerId     String
  name        String // e.g. "Ayesha"
  wristInches Float? // e.g. 6.5
  wristSize   String   @default("MEDIUM")
  preferences String? // free text, e.g. "Prefers pastels"
  savedDesign Json? // last saved bead/charm configuration for this profile
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

// ---------- Store settings (singleton) ----------

model StoreSettings {
  id                    String  @id @default("singleton")
  jazzcashAccountNumber String?
  jazzcashAccountName   String?
}
